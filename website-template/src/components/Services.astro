      description: 'Clear description of your third service offering and why customers choose it.',
    },
    {
      icon: '🔧',
      title: 'Service Four',
      description: 'Clear description of your fourth service offering and its key features.',
    },
    {
      icon: '📈',
      title: 'Service Five',
      description: 'Clear description of your fifth service offering and the results it delivers.',
    },
    {
      icon: '💬',
      title: 'Service Six',
      description: 'Clear description of your sixth service offering and customer testimonials.',
    },
  ];
</script>