---
import { SITE_CONFIG } from '../config/site.config';

const { sectionHeadline, sectionSubheadline, services } = SITE_CONFIG;
---

<section id="services" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="inline-block px-3 py-1 text-sm font-medium text-brand-700 bg-brand-50 rounded-full mb-4">
        What We Offer
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">{sectionHeadline}</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">{sectionSubheadline}</p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map((service) => (
        <div class="bg-gray-50 rounded-xl p-6 hover:shadow-lg transition-shadow border border-gray-100">
          <!-- Icon placeholder -->
          <div class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center mb-4">
            <span class="text-2xl">
              {service.icon === 'knitwear' && '👕'}
              {service.icon === 'fabrics' && '🧶'}
              {service.icon === 'garments' && '👔'}
            </span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">{service.title}</h3>
          <p class="text-gray-600 text-sm">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>