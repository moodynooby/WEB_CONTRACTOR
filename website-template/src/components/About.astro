---
import { SITE_CONFIG } from '../config/site.config';

const { 
  aboutHeadline, 
  aboutDescription, 
  aboutDescriptionExtra, 
  yearsExperience, 
  highlight1, 
  highlight2, 
  highlight3, 
  highlight4 
} = SITE_CONFIG;
---

<section id="about" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Image Side -->
      <div class="relative">
        <img
          src="https://images.unsplash.com/photo-1558591710-4b4a1ae0f04d?auto=format&fit=crop&q=80&w=600"
          alt="Textile manufacturing"
          class="rounded-2xl shadow-xl"
          loading="lazy"
        />
        <!-- Stats overlay card -->
        <div class="absolute -bottom-8 -right-8 bg-white rounded-xl shadow-lg p-6 hidden sm:block">
          <div class="text-3xl font-bold text-brand-600">{yearsExperience}</div>
          <div class="text-sm text-gray-600">Years of Excellence</div>
        </div>
      </div>

      <!-- Text Content -->
      <div>
        <span class="inline-block px-3 py-1 text-sm font-medium text-brand-700 bg-brand-50 rounded-full mb-4">
          About Us
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">{aboutHeadline}</h2>
        <p class="text-gray-600 mb-6 leading-relaxed">
          {aboutDescription}
        </p>
        <p class="text-gray-600 mb-8 leading-relaxed">
          {aboutDescriptionExtra}
        </p>

        <!-- Key highlights -->
        <div class="grid grid-cols-2 gap-4">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-brand-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-gray-700">{highlight1}</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-brand-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-gray-700">{highlight2}</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-brand-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-gray-700">{highlight3}</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-brand-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-gray-700">{highlight4}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>