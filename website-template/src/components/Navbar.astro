---
// Navbar.astro — Main site navigation
// TODO: Replace with client's logo and navigation links
---

<nav class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <!-- Logo / Brand Name -->
      <div class="flex items-center">
        <a href="/" class="text-xl font-bold text-brand-700">
          {BUSINESS_NAME}
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        <a href="#home" class="text-gray-700 hover:text-brand-600 transition-colors">Home</a>
        <a href="#services" class="text-gray-700 hover:text-brand-600 transition-colors">Services</a>
        <a href="#about" class="text-gray-700 hover:text-brand-600 transition-colors">About</a>
        <a href="#contact" class="text-gray-700 hover:text-brand-600 transition-colors">Contact</a>
        <!-- CTA Button -->
        <a
          href="#contact"
          class="bg-brand-600 text-white px-4 py-2 rounded-lg hover:bg-brand-700 transition-colors"
        >
          Get Started
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button id="mobile-menu-btn" class="text-gray-700 hover:text-brand-600">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t">
    <div class="px-4 py-3 space-y-2">
      <a href="#home" class="block text-gray-700 hover:text-brand-600">Home</a>
      <a href="#services" class="block text-gray-700 hover:text-brand-600">Services</a>
      <a href="#about" class="block text-gray-700 hover:text-brand-600">About</a>
      <a href="#contact" class="block text-gray-700 hover:text-brand-600">Contact</a>
      <a href="#contact" class="block bg-brand-600 text-white text-center px-4 py-2 rounded-lg mt-2">
        Get Started
      </a>
    </div>
  </div>
</nav>

<script>
  // Toggle mobile menu
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>