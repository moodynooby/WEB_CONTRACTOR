# LLM Provider Configuration
# Get free Groq API key at: https://console.groq.com/keys
# Optional: OpenRouter for fallback models

GROQ_API_KEY=gsk_your_key_here
OPENROUTER_API_KEY=optional_for_fallback

# Provider selection: "groq" (primary) or "openrouter" (fallback)
DEFAULT_PROVIDER=groq

# Model selection
# Groq models: llama-3.1-8b-instant, llama-3.3-70b-versatile, llama-3.2-90b-vision-preview
# OpenRouter free models: google/gemma-2-2b-it:free, mistralai/mistral-7b-instruct:free
DEFAULT_MODEL=llama-3.1-8b-instant
FALLBACK_MODEL=google/gemma-2-2b-it:free

# LLM Timeout
LLM_TIMEOUT=30

# Gmail SMTP Configuration
# Use App Password, not regular password
# Generate at: https://myaccount.google.com/apppasswords

GMAIL_EMAIL=your-email@gmail.com
GMAIL_PASSWORD=your-16-char-app-password

