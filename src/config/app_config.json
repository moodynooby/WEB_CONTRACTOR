  "agents": {
    "execution_order": [
      "content",
      "business",
      "technical",
      "performance"
    ],
    "weights": {
      "content": 0.3,
      "business": 0.3,
      "technical": 0.25,
      "performance": 0.15
    },
    "content": {
      "enabled": true,
      "weight": 0.3,
      "timeout": 30,
      "system_message": "You are a BRUTALLY HONEST content auditor. Analyze website copy for clarity, CTAs, value proposition, and trust signals. Scoring: 100=Perfect, 70=Good, 40=Needs improvement, 10=Terrible. Output ONLY valid JSON.",
      "prompt_template": "Analyze website content for '{business_name}' (industry: {bucket}).\n\nContent:\n{content}\n\nEvaluate:\n1. Value Proposition: Clear within 3 seconds?\n2. Call-to-Actions: Visible, specific, and compelling?\n3. Professional Tone: Appropriate for industry?\n4. Trust Signals: Testimonials, badges, credentials?\n5. Content Quality: Well-written, no errors?\n\nReturn ONLY JSON:\n{{\n  \"content_score\": <0-100>,\n  \"observations\": [\n    {{\n      \"type\": \"value_proposition|cta|tone|trust|content_quality\",\n      \"severity\": \"critical|warning|info\",\n      \"description\": \"specific finding\",\n      \"recommendation\": \"how to fix\"\n    }}\n  ]\n}}"
    },
    "business": {
      "enabled": true,
      "weight": 0.3,
      "timeout": 30,
      "llm_audit": {
        "enabled": true,
        "system_message": "You are a BRUTALLY HONEST business strategy expert. Evaluate industry-specific requirements. Scoring: 100=Perfect, 70=Average, 40=Poor, 10=Terrible. Be critical.",
        "prompt_template": "Evaluate {bucket} business website for '{business_name}'.\n\nContent:\n{content}\n\nCheck industry-specific requirements:\n1. Service Clarity: What they offer is clear?\n2. Target Audience: Clear who they serve?\n3. Differentiation: What makes them unique?\n4. Industry Standards: Meeting expectations?\n\nReturn ONLY JSON:\n{{\n  \"business_score\": <0-100>,\n  \"observations\": [\n    {{\n      \"type\": \"service_clarity|target_audience|differentiation|standards\",\n      \"severity\": \"critical|warning|info\",\n      \"description\": \"specific finding\",\n      \"recommendation\": \"how to fix\"\n    }}\n  ]\n}}"
      },
      "bucket_overrides": {
        "Developers": [
          {
            "id": "dev_github_link",
            "type": "link_match",
            "patterns": [
              "github.com",
              "gitlab.com",
              "bitbucket.org"
            ],
            "description": "No link to code repository",
            "remediation": "Add a link to your GitHub or code portfolio",
            "severity": "warning",
            "score_impact": 10
          },
          {
            "id": "dev_projects_showcase",
            "type": "text_match",
            "patterns": [
              "projects",
              "portfolio",
              "case studies",
              "work"
            ],
            "description": "No projects or portfolio section visible",
            "remediation": "Add a projects or portfolio section",
            "severity": "critical",
            "score_impact": 20
          },
          {
            "id": "dev_skills_section",
            "type": "text_match",
            "patterns": [
              "skills",
              "technologies",
              "tech stack",
              "languages"
            ],
            "description": "No skills or technologies section",
            "remediation": "Add a skills/technologies section",
            "severity": "warning",
            "score_impact": 10
          }
        ],
        "Marketing Agencies": [
          {
            "id": "agency_case_studies",
            "type": "text_match",
            "patterns": [
              "case studies",
              "success stories",
              "results",
              "portfolio"
            ],
            "description": "No case studies or results showcase",
            "remediation": "Add case studies demonstrating client results",
            "severity": "critical",
            "score_impact": 20
          },
          {
            "id": "agency_testimonials",
            "type": "text_match",
            "patterns": [
              "testimonial",
              "review",
              "client feedback"
            ],
            "description": "No client testimonials visible",
            "remediation": "Add client testimonials and reviews",
            "severity": "warning",
            "score_impact": 10
          },
          {
            "id": "agency_services_clear",
            "type": "text_match",
            "patterns": [
              "services",
              "what we do",
              "offerings",
              "solutions"
            ],
            "description": "Services not clearly defined",
            "remediation": "Create a clear services page",
            "severity": "warning",
            "score_impact": 10
          }
        ],
        "E-commerce": [
          {
            "id": "ecommerce_product_catalog",
            "type": "text_match",
            "patterns": [
              "products",
              "shop",
              "catalog",
              "collection"
            ],
            "description": "No product catalog visible",
            "remediation": "Add a clear product catalog or shop section",
            "severity": "critical",
            "score_impact": 25
          },
          {
            "id": "ecommerce_cart_checkout",
            "type": "link_match",
            "patterns": [
              "cart",
              "checkout",
              "add to cart",
              "buy now"
            ],
