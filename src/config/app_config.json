            "description": "No mention of secure payment options",
            "remediation": "Display trust badges and secure payment info",
            "severity": "warning",
            "score_impact": 15
          }
        ],
        "Restaurants": [
          {
            "id": "restaurant_menu",
            "type": "text_match",
            "patterns": [
              "menu",
              "our dishes",
              "food",
              "cuisine"
            ],
            "description": "No menu visible on website",
            "remediation": "Add a clear menu with prices and descriptions",
            "severity": "critical",
            "score_impact": 20
          },
          {
            "id": "restaurant_location_hours",
            "type": "text_match",
            "patterns": [
              "hours",
              "open",
              "location",
              "address",
              "contact"
            ],
            "description": "Missing location or hours",
            "remediation": "Add clear location, hours, and contact info",
            "severity": "critical",
            "score_impact": 20
          },
          {
            "id": "restaurant_reservation",
            "type": "link_match",
            "patterns": [
              "reserve",
              "booking",
              "reservation",
              "order online"
            ],
            "description": "No online reservation or ordering",
            "remediation": "Add online reservation or ordering capability",
            "severity": "warning",
            "score_impact": 10
          }
        ],
        "Photographers": [
          {
            "id": "photographer_portfolio",
            "type": "text_match",
            "patterns": [
              "portfolio",
              "gallery",
              "work",
              "photos",
              "shoots"
            ],
            "description": "No portfolio or gallery visible",
            "remediation": "Add a portfolio gallery showcasing your best work",
            "severity": "critical",
            "score_impact": 25
          },
          {
            "id": "photographer_services",
            "type": "text_match",
            "patterns": [
              "services",
              "packages",
              "pricing",
              "sessions"
            ],
            "description": "No services or pricing information",
            "remediation": "Add services and pricing packages",
            "severity": "warning",
            "score_impact": 10
          },
          {
            "id": "photographer_contact_booking",
            "type": "link_match",
            "patterns": [
              "contact",
              "book",
              "inquire",
              "hire"
            ],
            "description": "No clear contact or booking method",
            "remediation": "Add clear contact form or booking system",
            "severity": "warning",
            "score_impact": 10
          }
        ],
        "default": [
          {
            "id": "general_services_clear",
            "type": "text_match",
            "patterns": [
              "services",
              "what we do",
              "offerings",
              "products"
            ],
            "description": "Services or products not clearly defined",
            "remediation": "Clearly state what you offer",
            "severity": "warning",
            "score_impact": 10
          },
          {
            "id": "general_contact_info",
            "type": "text_match",
            "patterns": [
              "contact",
              "email",
              "phone",
              "address"
            ],
            "description": "Contact information not easily visible",
            "remediation": "Make contact information prominent",
            "severity": "warning",
            "score_impact": 10
          }
        ]
      }
    },
    "technical": {
      "enabled": true,
      "weight": 0.25,
      "timeout": 30,
      "checks": {
        "check_robots_txt": false,
        "title_missing_penalty": 20,
        "title_long_penalty": 5,
        "description_missing_penalty": 15,
        "description_long_penalty": 5,
        "og_missing_penalty": 10,
        "og_incomplete_penalty": 5,
        "viewport_missing_penalty": 20,
        "canonical_missing_penalty": 5,
        "structured_data_missing_penalty": 10,
        "robots_txt_missing_penalty": 5,
        "h1_missing_penalty": 10,
        "h1_multiple_penalty": 5,
        "alt_text_missing_penalty": 10,
        "https_missing_penalty": 20
      },
      "early_exit_rules": {
        "max_critical_issues": 2
      }
    },
    "performance": {
      "enabled": true,
      "weight": 0.15,
      "timeout": 30,
      "thresholds": {
        "max_html_size_kb": 100,
        "max_inline_css_kb": 50,
        "max_inline_js_kb": 50,
        "max_resources": 50,
        "max_response_time_ms": 1000
      }
    }
  },
  "email_generation": {
    "enabled": true,
    "timeout": 30,
    "system_message": "Write a personalized B2B cold email. Output ONLY valid JSON.",
    "prompt_template": "Generate a short cold email for {business_name}.\n\nAudit Results:\n{issue_summary}\n\nEmail must:\n1. Mention 1 specific site detail.\n2. Mention 1-2 critical issues (design, speed, or mobile).\n3. Explain the business impact (lost sales).\n4. Offer a quick audit/call.\n5. Max 120 words, no placeholders, no signature.\n\nReturn ONLY JSON:\n{{\"subject\": \"your subject line here\", \"body\": \"your email body here\"}}"
  }
